{
  "version": 1,
  "templates": [
    {
      "id": "amazon-products",
      "name": "Amazon Product Search",
      "description": "Extracts title, price, star rating, review count and product image from Amazon search result pages.",
      "site": "amazon.com",
      "category": "ecommerce",
      "author": "scrapeman",
      "uses": 0,
      "config": {
        "blockSelector": "[data-component-type='s-search-result']",
        "fields": [
          { "name": "Title",   "type": "text",   "required": true,  "selector": "h2 .a-text-normal",        "confidence": 92 },
          { "name": "Price",   "type": "text",   "required": false, "selector": ".a-price .a-offscreen",     "confidence": 88 },
          { "name": "Rating",  "type": "text",   "required": false, "selector": ".a-icon-alt",               "confidence": 83 },
          { "name": "Reviews", "type": "number", "required": false, "selector": ".a-size-base.s-underline-text", "confidence": 78 },
          { "name": "Image",   "type": "image",  "required": false, "selector": ".s-image",                  "confidence": 91 },
          { "name": "Link",    "type": "link",   "required": false, "selector": "h2 a",                      "confidence": 95 }
        ],
        "maxPages": 5,
        "delayMin": 3,
        "delayMax": 6
      }
    },
    {
      "id": "olx-jobs",
      "name": "OLX Job Listings",
      "description": "Scrapes job offers from OLX.pl — title, employer, salary range and location. Works on the main job search results page.",
      "site": "olx.pl",
      "category": "jobs",
      "author": "scrapeman",
      "uses": 0,
      "config": {
        "blockSelector": "[data-cy='l-card']",
        "fields": [
          { "name": "Title",    "type": "text", "required": true,  "selector": "[data-cy='ad-card-title']",   "confidence": 95 },
          { "name": "Salary",   "type": "text", "required": false, "selector": "[data-testid='price-value']", "confidence": 80 },
          { "name": "Location", "type": "text", "required": false, "selector": "[data-testid='location-date']","confidence": 82 },
          { "name": "Link",     "type": "link", "required": false, "selector": "a[href*='/oferta/']",         "confidence": 93 }
        ],
        "maxPages": 10,
        "delayMin": 2,
        "delayMax": 4
      }
    },
    {
      "id": "linkedin-jobs",
      "name": "LinkedIn Job Search",
      "description": "Extracts job title, company name, location and apply link from LinkedIn public job search (no login required).",
      "site": "linkedin.com",
      "category": "jobs",
      "author": "scrapeman",
      "uses": 0,
      "config": {
        "blockSelector": ".jobs-search__results-list li",
        "fields": [
          { "name": "Title",    "type": "text", "required": true,  "selector": ".base-search-card__title",    "confidence": 91 },
          { "name": "Company",  "type": "text", "required": false, "selector": ".base-search-card__subtitle", "confidence": 89 },
          { "name": "Location", "type": "text", "required": false, "selector": ".job-search-card__location",  "confidence": 85 },
          { "name": "Link",     "type": "link", "required": false, "selector": ".base-card__full-link",       "confidence": 93 }
        ],
        "maxPages": 5,
        "delayMin": 3,
        "delayMax": 7
      }
    },
    {
      "id": "pracuj-jobs",
      "name": "Pracuj.pl Job Listings",
      "description": "Scrapes Polish job portal Pracuj.pl — position title, employer, salary and city from the search results listing.",
      "site": "pracuj.pl",
      "category": "jobs",
      "author": "scrapeman",
      "uses": 0,
      "config": {
        "blockSelector": "[data-test='default-offer']",
        "fields": [
          { "name": "Title",    "type": "text", "required": true,  "selector": "[data-test='offer-title']",   "confidence": 93 },
          { "name": "Company",  "type": "text", "required": false, "selector": "[data-test='text-company-name']", "confidence": 88 },
          { "name": "Salary",   "type": "text", "required": false, "selector": "[data-test='offer-salary']",  "confidence": 82 },
          { "name": "Location", "type": "text", "required": false, "selector": "[data-test='text-region']",   "confidence": 84 },
          { "name": "Link",     "type": "link", "required": false, "selector": "a[href*='pracuj.pl/praca/']", "confidence": 91 }
        ],
        "maxPages": 10,
        "delayMin": 2,
        "delayMax": 5
      }
    },
    {
      "id": "otodom-flats",
      "name": "Otodom Apartment Listings",
      "description": "Extracts apartment offers from Otodom.pl — title, asking price, area, number of rooms and location.",
      "site": "otodom.pl",
      "category": "realestate",
      "author": "scrapeman",
      "uses": 0,
      "config": {
        "blockSelector": "[data-cy='listing-item']",
        "fields": [
          { "name": "Title",    "type": "text", "required": true,  "selector": "[data-cy='listing-item-title']",       "confidence": 93 },
          { "name": "Price",    "type": "text", "required": false, "selector": "[aria-label*='Cena'], .css-1mojccp", "confidence": 86 },
          { "name": "Area",     "type": "text", "required": false, "selector": "[aria-label*='Powierzchnia'], [data-cy='listing-item-area']", "confidence": 81 },
          { "name": "Rooms",    "type": "text", "required": false, "selector": "[aria-label*='Liczba pokoi']",         "confidence": 79 },
          { "name": "Location", "type": "text", "required": false, "selector": "p[class*='location'], [aria-label*='Adres']", "confidence": 83 },
          { "name": "Link",     "type": "link", "required": false, "selector": "a[href*='/oferta/']",                 "confidence": 92 }
        ],
        "maxPages": 10,
        "delayMin": 2,
        "delayMax": 5
      }
    },
    {
      "id": "hacker-news",
      "name": "Hacker News Front Page",
      "description": "Scrapes Hacker News stories — title, external link, points, author and comment count. Reliable due to stable HTML structure.",
      "site": "news.ycombinator.com",
      "category": "news",
      "author": "scrapeman",
      "uses": 0,
      "config": {
        "blockSelector": ".athing",
        "fields": [
          { "name": "Title",    "type": "text",   "required": true,  "selector": ".titleline > a",           "confidence": 96 },
          { "name": "Link",     "type": "link",   "required": false, "selector": ".titleline > a",           "confidence": 96 },
          { "name": "Points",   "type": "number", "required": false, "selector": ".score",                   "confidence": 89 },
          { "name": "Author",   "type": "text",   "required": false, "selector": ".hnuser",                  "confidence": 87 },
          { "name": "Comments", "type": "number", "required": false, "selector": ".subline a:last-child",    "confidence": 83 }
        ],
        "maxPages": 3,
        "delayMin": 1,
        "delayMax": 2
      }
    },
    {
      "id": "reddit-posts",
      "name": "Reddit Subreddit Posts",
      "description": "Scrapes any subreddit's post feed — title, upvotes, comment count, author and post link. Works on new Reddit.",
      "site": "reddit.com",
      "category": "social",
      "author": "scrapeman",
      "uses": 0,
      "config": {
        "blockSelector": "[data-testid='post-container']",
        "fields": [
          { "name": "Title",    "type": "text",   "required": true,  "selector": "[data-click-id='title']",            "confidence": 91 },
          { "name": "Upvotes",  "type": "number", "required": false, "selector": "[id^='vote-arrows'] .text-tone-2",   "confidence": 78 },
          { "name": "Comments", "type": "number", "required": false, "selector": "[data-click-id='comments']",         "confidence": 82 },
          { "name": "Author",   "type": "text",   "required": false, "selector": "[data-testid='post_author_link']",   "confidence": 86 },
          { "name": "Link",     "type": "link",   "required": false, "selector": "[data-click-id='title'] a",          "confidence": 89 }
        ],
        "maxPages": 5,
        "delayMin": 2,
        "delayMax": 4
      }
    },
    {
      "id": "booking-hotels",
      "name": "Booking.com Hotel Search",
      "description": "Extracts hotel name, guest review score, price per night and direct booking link from Booking.com search results.",
      "site": "booking.com",
      "category": "travel",
      "author": "scrapeman",
      "uses": 0,
      "config": {
        "blockSelector": "[data-testid='property-card']",
        "fields": [
          { "name": "Name",  "type": "text",   "required": true,  "selector": "[data-testid='title']",                        "confidence": 93 },
          { "name": "Score", "type": "number", "required": false, "selector": "[data-testid='review-score'] div:first-child", "confidence": 82 },
          { "name": "Price", "type": "text",   "required": false, "selector": "[data-testid='price-and-discounted-price']",   "confidence": 87 },
          { "name": "Link",  "type": "link",   "required": false, "selector": "[data-testid='title-link']",                   "confidence": 91 }
        ],
        "maxPages": 5,
        "delayMin": 3,
        "delayMax": 7
      }
    },
    {
      "id": "imdb-chart",
      "name": "IMDb Movie Chart",
      "description": "Scrapes IMDb Top 250 or any list chart — movie title, release year, IMDb rating and detail page link.",
      "site": "imdb.com",
      "category": "other",
      "author": "scrapeman",
      "uses": 0,
      "config": {
        "blockSelector": ".ipc-metadata-list-summary-item",
        "fields": [
          { "name": "Title",  "type": "text",   "required": true,  "selector": ".ipc-title__text",                     "confidence": 91 },
          { "name": "Year",   "type": "text",   "required": false, "selector": ".dli-title-metadata-item:first-child",  "confidence": 83 },
          { "name": "Rating", "type": "number", "required": false, "selector": ".ipc-rating-star--rating",              "confidence": 86 },
          { "name": "Link",   "type": "link",   "required": false, "selector": ".ipc-title-link-wrapper",               "confidence": 93 }
        ],
        "maxPages": 3,
        "delayMin": 2,
        "delayMax": 4
      }
    },
    {
      "id": "github-repos",
      "name": "GitHub Repository Search",
      "description": "Extracts repository name, description, primary language, star count and link from GitHub search results.",
      "site": "github.com",
      "category": "other",
      "author": "scrapeman",
      "uses": 0,
      "config": {
        "blockSelector": "[data-testid='results-list'] li",
        "fields": [
          { "name": "Name",        "type": "text",   "required": true,  "selector": "[data-testid='results-list'] li h3 a", "confidence": 90 },
          { "name": "Description", "type": "text",   "required": false, "selector": ".search-result-item p",                "confidence": 82 },
          { "name": "Language",    "type": "text",   "required": false, "selector": "[itemprop='programmingLanguage']",      "confidence": 84 },
          { "name": "Stars",       "type": "number", "required": false, "selector": "a[href*='/stargazers']",               "confidence": 86 },
          { "name": "Link",        "type": "link",   "required": false, "selector": "h3 a",                                 "confidence": 92 }
        ],
        "maxPages": 5,
        "delayMin": 1,
        "delayMax": 3
      }
    }
  ]
}
